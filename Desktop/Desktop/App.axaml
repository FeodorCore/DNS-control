<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Desktop.App"
             xmlns:local="using:Desktop"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

        <!-- General Button -->
        <Style Selector="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1D2939"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:hover">
            <Setter Property="Background" Value="#F9FAFB"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#F2F4F7"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <!-- Primary Button (Оранжевый) -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#ff9519"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#ff9519"/>
        </Style>
        <Style Selector="Button.Primary:hover">
            <Setter Property="Background" Value="#e68617"/>
        </Style>
        <Style Selector="Button.Primary:pressed">
            <Setter Property="Background" Value="#cc7714"/>
        </Style>

        <!-- Success Button -->
        <Style Selector="Button.Success">
            <Setter Property="Background" Value="#12B76A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#12B76A"/>
        </Style>
        <Style Selector="Button.Success:hover">
            <Setter Property="Background" Value="#039855"/>
        </Style>

        <!-- Danger Button -->
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#D92D20"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D92D20"/>
        </Style>
        <Style Selector="Button.Danger:hover">
            <Setter Property="Background" Value="#B42318"/>
        </Style>

        <!-- Input Controls -->
        <Style Selector="TextBox, ComboBox, DatePicker">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>
        <Style Selector="TextBox:focus, ComboBox:focus, DatePicker:focus">
            <Setter Property="BorderBrush" Value="#ff9519"/>
        </Style>
        <Style Selector="TextBox:disabled, ComboBox:disabled, DatePicker:disabled">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#667085"/>
        </Style>

        <!-- Labels -->
        <Style Selector="TextBlock.Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="500"/>
        </Style>
        <Style Selector="TextBlock.Header">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="700"/>
            <Setter Property="Foreground" Value="#101828"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- Lists -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBoxItem:hover">
            <Setter Property="Background" Value="#F9FAFB"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#FFF0E0"/>
            <Setter Property="BorderBrush" Value="#ff9519"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <!-- DataGrid -->
        <Style Selector="DataGrid">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#EAECF0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="52"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#475467"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="#EAECF0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>
        <Style Selector="DataGridRow:hover">
            <Setter Property="Background" Value="#F9FAFB"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#EAECF0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Application.Styles>
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
</Application>