<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Desktop.ViewModels"
             x:Class="Desktop.Views.CategoriesView"
             x:DataType="vm:CategoriesViewModel">
    <Grid ColumnDefinitions="300, *" ColumnSpacing="24">
        <!-- Левая колонка: поиск + список категорий -->
        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1"
                Padding="16">
            <Grid RowDefinitions="Auto, *">
                <!-- Поисковая строка -->
                <Border Grid.Row="0" Background="#F9FAFB" CornerRadius="8" BorderBrush="#E9ECEF" BorderThickness="1"
                        Padding="10,4" Margin="0,0,0,12">
                    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#98A2B3" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 PlaceholderText="Поиск по названию..."
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="4,4"
                                 FontSize="14" />
                    </Grid>
                </Border>

                <!-- Список категорий -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                         DisplayMemberBinding="{Binding Name}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
            </Grid>
        </Border>

        <!-- Правая колонка: форма редактирования -->
        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1"
                Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="18">
                    <TextBlock Classes="Header" Text="Редактирование категории" />

                    <StackPanel IsEnabled="{Binding SelectedCategory, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Classes="Label" Text="Название категории" />
                        <TextBox Text="{Binding SelectedCategory.Name, Mode=TwoWay}" PlaceholderText="Введите название" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,24,0,0">
                        <Button Content="Добавить" Command="{Binding AddCommand}" Classes="Primary" />
                        <Button Content="Сохранить" Command="{Binding SaveCommand}" Classes="Primary"
                                IsEnabled="{Binding SelectedCategory, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button Content="Удалить" Command="{Binding DeleteCommand}" Classes="Danger" Margin="12,0,0,0"
                                IsVisible="{Binding CanDelete}"
                                IsEnabled="{Binding SelectedCategory, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>