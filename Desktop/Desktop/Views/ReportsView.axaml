<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Desktop.ViewModels"
             x:Class="Desktop.Views.ReportsView"
             x:DataType="vm:ReportsViewModel"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto, Auto, Auto" Margin="10">
        <!-- Строка 0: тип отчёта -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,10">
            <TextBlock Text="Выберите отчёт:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding ReportTypes}"
                      SelectedItem="{Binding SelectedReport, Mode=TwoWay}"
                      Width="200" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Строка 1: период и категория -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Период:" VerticalAlignment="Center"/>
            <TextBlock Text="с" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding DateFrom}" VerticalAlignment="Center"/>
            <TextBlock Text="по" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding DateTo}" VerticalAlignment="Center"/>
            <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                      Width="150" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Строка 2: экспорт -->
        <Button Grid.Row="2" Content="Экспорт в Excel" Command="{Binding ExportToExcelCommand}"
                HorizontalAlignment="Right" Width="150"/>
    </Grid>
</UserControl>