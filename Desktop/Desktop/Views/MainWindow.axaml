<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Desktop.ViewModels"
        xmlns:views="using:Desktop.Views"
        x:Class="Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DNS Учёт"
        Width="1100" Height="650"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="200, *">
        <!-- Side menu -->
        <Border Grid.Column="0" Background="#F0F0F0">
            <ListBox ItemsSource="{Binding MenuItems}"
                     x:Name="menuList"
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:NavigationItem">
                        <TextBlock Text="{Binding Title}" FontSize="16" Margin="10"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Content area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="10"/>
    </Grid>
</Window>