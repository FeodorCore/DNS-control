<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Desktop.ViewModels"
             x:Class="Desktop.Views.SalesView"
             x:DataType="vm:SalesViewModel">
    <Grid RowDefinitions="Auto, Auto, *, Auto, Auto" Margin="10">
        <!-- Шапка -->
        <StackPanel Orientation="Horizontal" Spacing="15">
            <TextBlock Text="Продажа (новый чек)" FontSize="16" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Дата" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding SaleDatetime, Mode=TwoWay}"/>
            </StackPanel>
        </StackPanel>

        <!-- Заголовки -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *, *, *, *" Margin="0,10,0,5">
            <TextBlock Text="Товар" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2,0"/>
            <TextBlock Grid.Column="1" Text="Кол-во" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Цена продажи" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="Себест-ть" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="Сумма" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Список позиций -->
        <ListBox Grid.Row="2" x:Name="itemsList" ItemsSource="{Binding Items}" Margin="0,5" BorderThickness="1" BorderBrush="#DDDDDD">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:SaleItemViewModel">
                    <Grid ColumnDefinitions="*, *, *, *, *" HorizontalAlignment="Stretch">
                        <ComboBox ItemsSource="{Binding $parent[UserControl].DataContext.Products}"
                                  SelectedValue="{Binding ProductId, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  SelectedValueBinding="{Binding ProductId}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Margin="2"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Quantity, Mode=TwoWay}"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 Margin="4,0"
                                 TextAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding UnitSalePrice, Mode=TwoWay}"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 Margin="4,0"
                                 TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding UnitCostPrice, StringFormat={}{0:F2}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="8,0"/>
                        <TextBlock Grid.Column="4" Text="{Binding Total, StringFormat={}{0:F2}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="8,0" FontWeight="SemiBold"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Итого -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
            <TextBlock Text="Итого по чеку:" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding OverallTotal, StringFormat={}{0:F2} ₽}" FontWeight="Bold" FontSize="16" Margin="10,0"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <Button Content="Добавить позицию" Command="{Binding AddItemCommand}"/>
            <Button Content="Удалить позицию" Command="{Binding DeleteItemCommand}"
                    CommandParameter="{Binding SelectedItem, ElementName=itemsList}"/>
            <Button Content="Сохранить продажу" Command="{Binding SaveSaleCommand}" Background="#FFD700"/>
        </StackPanel>
    </Grid>
</UserControl>
